{
  "name": "@elevateinformatics/gtasks-mcp",
  "version": "1.0.0",
  "description": "MCP server for interacting with Google Tasks",
  "license": "MIT",
  "author": "Elevate Informatics",
  "homepage": "https://github.com/elevateinformatics/gtasks-mcp",
  "bugs": "https://github.com/elevateinformatics/gtasks-mcp/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/elevateinformatics/gtasks-mcp.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "type": "module",
  "bin": {
    "gtasks-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
